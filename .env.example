# ---------------------------------------------------------
# JS Cases Customizer — Environment Variables
# Copy this file to .env.local and fill in real values.
# ---------------------------------------------------------

# ----- Shopify -----
# The public domain of the Shopify store. Used to build the cart permalink.
# Use the primary domain, NOT the myshopify.com domain, so the customer stays on the branded checkout.
NEXT_PUBLIC_SHOPIFY_DOMAIN=jscases.co

# The Shopify variant ID of your "Custom Phone Case" product. ONE variant is
# enough — phone model is sent as a line item property, not as a variant.
# Required: Add to Cart will refuse to redirect until this is set.
# Find it in Shopify Admin → Products → [your custom case product] → Variants
# (numeric ID, not the GID).
NEXT_PUBLIC_DEFAULT_CUSTOM_CASE_VARIANT_ID=REPLACE_WITH_SINGLE_VARIANT_ID

# OPTIONAL: per-case-type variants. Set EITHER of these if you want different
# prices for solid vs transparent cases — otherwise the default above is used
# for both. Leave blank or unset to use the default.
NEXT_PUBLIC_SOLID_CASE_VARIANT_ID=
NEXT_PUBLIC_TRANSPARENT_CASE_VARIANT_ID=

# ----- Storage provider -----
# Options: "placeholder" | "supabase" | "cloudinary"
# "placeholder" returns mock URLs without uploading (good for local dev).
STORAGE_PROVIDER=placeholder

# ----- Supabase (only if STORAGE_PROVIDER=supabase) -----
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=js-cases-designs

# ----- Cloudinary (only if STORAGE_PROVIDER=cloudinary) -----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=js-cases-designs
